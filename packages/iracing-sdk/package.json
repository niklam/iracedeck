{
  "name": "@iracedeck/iracing-sdk",
  "version": "0.13.0",
  "description": "iRacing SDK for Node.js - telemetry reading and broadcast commands",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "bin": {
    "telemetry-snapshot": "dist/cli/telemetry-snapshot.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test-native": "node -e \"import('@iracedeck/iracing-native').then(console.log).catch(console.error)\"",
    "telemetry-snapshot": "node dist/cli/telemetry-snapshot.js"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@iracedeck/iracing-native": "workspace:*",
    "@iracedeck/logger": "workspace:*",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@types/node": "25.3.5",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "iracing",
    "sdk",
    "telemetry",
    "racing",
    "simulation"
  ],
  "license": "MIT"
}
