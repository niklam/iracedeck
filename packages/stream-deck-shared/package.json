{
  "name": "@iracedeck/stream-deck-shared",
  "version": "1.0.0",
  "description": "Shared utilities for Stream Deck plugins",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./build": {
      "import": "./dist/build/index.js",
      "types": "./dist/build/index.d.ts"
    },
    "./pi-components": {
      "import": "./dist/pi-components.js"
    }
  },
  "scripts": {
    "build": "tsc && rollup -c && npm run copy:partials",
    "build:pi": "rollup -c",
    "copy:partials": "node -e \"const fs=require('fs');const path=require('path');fs.cpSync('src/pi-templates',path.join('dist','pi-templates'),{recursive:true})\"",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@iracedeck/iracing-sdk": "workspace:*",
    "@iracedeck/logger": "workspace:*",
    "ejs": "^4.0.1",
    "keysender": "^2.4.0",
    "zod": "^3.25.76"
  },
  "peerDependencies": {
    "@elgato/streamdeck": "^2.0.0"
  },
  "devDependencies": {
    "@elgato/streamdeck": "^2.0.1",
    "@elgato/utils": "^0.4.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/ejs": "^3.1.5",
    "@types/node": "~24.0.15",
    "rimraf": "^5.0.10",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "license": "MIT"
}
