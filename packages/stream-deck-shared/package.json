{
  "name": "@iracedeck/stream-deck-shared",
  "version": "1.0.0",
  "description": "Shared utilities for Stream Deck plugins",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./pi-components": {
      "import": "./dist/pi-components.js"
    }
  },
  "scripts": {
    "build": "tsc && rollup -c",
    "build:pi": "rollup -c",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@iracedeck/logger": "workspace:*",
    "@iracedeck/iracing-sdk": "workspace:*",
    "keysender": "^2.3.1",
    "zod": "^3.24.0"
  },
  "peerDependencies": {
    "@elgato/streamdeck": "^2.0.0"
  },
  "devDependencies": {
    "@elgato/streamdeck": "^2.0.0",
    "@elgato/utils": "^0.4.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/node": "~24.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.2",
    "tslib": "^2.6.2",
    "typescript": "^5.2.2",
    "vitest": "^4.0.16"
  },
  "license": "MIT"
}
