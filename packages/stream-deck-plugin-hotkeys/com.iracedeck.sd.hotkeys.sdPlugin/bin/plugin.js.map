export default "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 72 72\" data-no-na=\"true\">\n  <g filter=\"url(#activity-state)\">\n    <!-- Keyboard key outline -->\n    <rect x=\"12\" y=\"12\" width=\"48\" height=\"36\" rx=\"4\" ry=\"4\"\n          fill=\"none\"\n          stroke=\"{{color}}\"\n          stroke-width=\"2.5\"\n          stroke-linejoin=\"round\"/>\n    <!-- Key cap depression effect -->\n    <rect x=\"16\" y=\"16\" width=\"40\" height=\"28\" rx=\"2\" ry=\"2\"\n          fill=\"none\"\n          stroke=\"{{color}}\"\n          stroke-width=\"1.5\"\n          stroke-linejoin=\"round\"/>\n    <!-- iRacing \"i\" indicator -->\n    <circle cx=\"54\" cy=\"18\" r=\"6\" fill=\"{{color}}\"/>\n    <text x=\"54\" y=\"21\" text-anchor=\"middle\" fill=\"#ffffff\" font-family=\"sans-serif\" font-size=\"10\" font-weight=\"bold\">i</text>\n    {{textElement}}\n  </g>\n</svg>\n";