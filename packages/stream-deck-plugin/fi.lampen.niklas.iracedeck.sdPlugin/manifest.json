{
  "$schema": "https://schemas.elgato.com/streamdeck/plugins/manifest.json",
  "Name": "iRaceDeck",
  "Version": "0.1.0.0",
  "Author": "Niklas Lampén",
  "Actions": [
    {
      "Name": "Display Speed",
      "UUID": "fi.lampen.niklas.iracedeck.vehicle.display-speed",
      "Icon": "imgs/actions/vehicle/display-speed/icon",
      "Tooltip": "Displays current speed from iRacing. Press to toggle between MPH and KPH.",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/vehicle/display-speed/key",
          "TitleAlignment": "bottom",
          "FontSize": 18
        }
      ]
    },
    {
      "Name": "Display Gear",
      "UUID": "fi.lampen.niklas.iracedeck.vehicle.display-gear",
      "Icon": "imgs/actions/vehicle/display-gear/icon",
      "Tooltip": "Displays current gear from iRacing.",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/vehicle/display-gear/key",
          "TitleAlignment": "bottom",
          "FontSize": 18
        }
      ]
    },
    {
      "Name": "Display Sky",
      "UUID": "fi.lampen.niklas.iracedeck.environment.display-sky",
      "Icon": "imgs/actions/environment/display-sky/icon",
      "Tooltip": "Displays current sky conditions from iRacing.",
      "Controllers": [
        "Keypad"
      ],
      "States": [
        {
          "Image": "imgs/actions/environment/display-sky/key",
          "TitleAlignment": "bottom",
          "FontSize": 9
        }
      ]
    }
  ],
  "Category": "iRaceDeck",
  "CategoryIcon": "imgs/plugin/category-icon",
  "CodePath": "bin/plugin.js",
  "Description": "Open source iRacing Stream Deck support",
  "Icon": "imgs/plugin/marketplace",
  "SDKVersion": 3,
  "Software": {
    "MinimumVersion": "6.9"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "UUID": "fi.lampen.niklas.iracedeck"
}
