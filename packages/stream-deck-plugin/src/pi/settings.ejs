<!doctype html>
<html lang="en">
	<head>
		<%- include('head-common') %>
	</head>
	<body>
		<sdpi-item label="Connection">
			<sdpi-checkbox
				setting="disableWhenDisconnected"
				label="Disable buttons when iRacing is not connected"
				global
				default="true"
			></sdpi-checkbox>
		</sdpi-item>

		<sdpi-item label="Focus iRacing">
			<sdpi-checkbox
				setting="focusIRacingWindow"
				label="Focus iRacing window before sending keys"
				global
			></sdpi-checkbox>
		</sdpi-item>

		<%- include('version') %>
	</body>
</html>
