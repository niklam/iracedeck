<!doctype html>
<html lang="en">
	<head>
		<%- include('head-common') %>
	</head>
	<body>
		<sdpi-item label="Mode">
			<sdpi-select id="mode-select" setting="mode" default="open-chat">
				<option value="open-chat">Open Chat</option>
				<option value="reply">Reply to Chat</option>
				<option value="whisper">Whisper</option>
				<option value="respond-pm">Respond to Last PM</option>
				<option value="cancel">Cancel Chat</option>
				<option value="send-message">Send Message</option>
				<option value="macro">Macro (1-15)</option>
			</sdpi-select>
		</sdpi-item>

		<sdpi-item label="Message Text" id="message-item" class="hidden">
			<sdpi-textfield setting="message" placeholder="Enter message to send"></sdpi-textfield>
		</sdpi-item>

		<sdpi-item id="template-help" class="hidden">
			<details>
				<summary style="cursor: pointer; color: #9e9e9e; font-size: 11px;">
					Template Variables (use {{variable}} syntax)
				</summary>
				<div style="font-size: 10px; color: #9e9e9e; padding: 4px 0; line-height: 1.6;">
					<b>Self:</b> self.name, self.first_name, self.last_name, self.car_number,
					self.position, self.class_position, self.lap, self.incidents<br>
					<b>Track Ahead:</b> track_ahead.name, track_ahead.first_name, track_ahead.last_name, track_ahead.car_number<br>
					<b>Track Behind:</b> track_behind.name, track_behind.first_name, track_behind.last_name, track_behind.car_number<br>
					<b>Race Ahead:</b> race_ahead.name, race_ahead.first_name, race_ahead.car_number<br>
					<b>Race Behind:</b> race_behind.name, race_behind.first_name, race_behind.car_number<br>
					<b>Session:</b> session.type, session.laps_remaining, session.time_remaining<br>
					<b>Track:</b> track.name, track.short_name<br>
					<br>
					<i>All driver groups also have: abbrev_name, irating, license, laps_completed</i>
				</div>
			</details>
		</sdpi-item>

		<sdpi-item label="Macro Number" id="macro-item" class="hidden">
			<sdpi-select setting="macroNumber" default="1">
				<% for (let i = 1; i <= 15; i++) { %>
				<option value="<%= i %>">Macro <%= i %></option>
				<% } %>
			</sdpi-select>
		</sdpi-item>

		<sdpi-item label="Icon Color">
			<sdpi-color setting="iconColor" default="#4a90d9"></sdpi-color>
		</sdpi-item>

		<sdpi-item label="Key Text">
			<sdpi-textarea setting="keyText" rows="2" placeholder="Leave empty for default"></sdpi-textarea>
		</sdpi-item>

		<%- include('global-key-bindings', {
			subtitle: 'Chat Key Bindings',
			keyBindings: require('./data/key-bindings.json').chat
		}) %>

		<script>
			function updateVisibility(mode) {
				const messageItem = document.getElementById("message-item");
				const macroItem = document.getElementById("macro-item");
				const templateHelp = document.getElementById("template-help");

				if (messageItem) {
					messageItem.classList.toggle("hidden", mode !== "send-message");
				}
				if (templateHelp) {
					templateHelp.classList.toggle("hidden", mode !== "send-message");
				}
				if (macroItem) {
					macroItem.classList.toggle("hidden", mode !== "macro");
				}
			}

			async function initialize() {
				await customElements.whenDefined("sdpi-select");

				const modeSelect = document.getElementById("mode-select");
				if (modeSelect) {
					const initialValue = modeSelect.value || "open-chat";
					updateVisibility(initialValue);

					modeSelect.addEventListener("change", (ev) => {
						updateVisibility(ev.target.value || "open-chat");
					});
					modeSelect.addEventListener("input", (ev) => {
						updateVisibility(ev.target.value || "open-chat");
					});

					// Polling fallback for reliable detection
					let lastMode = modeSelect.value || "open-chat";
					setInterval(() => {
						const currentMode = modeSelect.value;
						if (currentMode && currentMode !== lastMode) {
							lastMode = currentMode;
							updateVisibility(currentMode);
						}
					}, 100);
				}
			}

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", initialize);
			} else {
				initialize();
			}
		</script>

		<style>
			.hidden { display: none !important; }
		</style>
	</body>
</html>
