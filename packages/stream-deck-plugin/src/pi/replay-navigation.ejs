<!doctype html>
<html lang="en">
	<head>
		<%- include('head-common') %>
	</head>
	<body>
		<sdpi-item label="Navigation">
			<sdpi-select id="navigation-select" setting="navigation" default="next-session">
				<option value="next-session">Next Session</option>
				<option value="prev-session">Previous Session</option>
				<option value="next-lap">Next Lap</option>
				<option value="prev-lap">Previous Lap</option>
				<option value="next-incident">Next Incident</option>
				<option value="prev-incident">Previous Incident</option>
				<option value="jump-to-start">Jump to Start</option>
				<option value="jump-to-end">Jump to End</option>
				<option value="set-play-position">Set Play Position</option>
				<option value="search-session-time">Search Session Time</option>
				<option value="erase-tape">Erase Tape</option>
			</sdpi-select>
		</sdpi-item>

		<sdpi-item label="Frame Number" id="frame-item" class="hidden">
			<sdpi-textfield setting="frameNumber" placeholder="0" type="number"></sdpi-textfield>
		</sdpi-item>

		<sdpi-item label="Session Number" id="session-num-item" class="hidden">
			<sdpi-textfield setting="sessionNum" placeholder="0" type="number"></sdpi-textfield>
		</sdpi-item>

		<sdpi-item label="Session Time (ms)" id="session-time-item" class="hidden">
			<sdpi-textfield setting="sessionTimeMs" placeholder="0" type="number"></sdpi-textfield>
		</sdpi-item>

		<script>
			function updateVisibility(navigation) {
				const frameItem = document.getElementById("frame-item");
				const sessionNumItem = document.getElementById("session-num-item");
				const sessionTimeItem = document.getElementById("session-time-item");

				if (frameItem) {
					frameItem.classList.toggle("hidden", navigation !== "set-play-position");
				}
				if (sessionNumItem) {
					sessionNumItem.classList.toggle("hidden", navigation !== "search-session-time");
				}
				if (sessionTimeItem) {
					sessionTimeItem.classList.toggle("hidden", navigation !== "search-session-time");
				}
			}

			async function initialize() {
				await customElements.whenDefined("sdpi-select");

				const navigationSelect = document.getElementById("navigation-select");
				if (navigationSelect) {
					const initialValue = navigationSelect.value || "next-session";
					updateVisibility(initialValue);

					navigationSelect.addEventListener("change", (ev) => {
						updateVisibility(ev.target.value || "next-session");
					});
					navigationSelect.addEventListener("input", (ev) => {
						updateVisibility(ev.target.value || "next-session");
					});

					// Polling fallback for reliable detection
					let lastNavigation = navigationSelect.value || "next-session";
					setInterval(() => {
						const currentNavigation = navigationSelect.value;
						if (currentNavigation && currentNavigation !== lastNavigation) {
							lastNavigation = currentNavigation;
							updateVisibility(currentNavigation);
						}
					}, 100);
				}
			}

			if (document.readyState === "loading") {
				document.addEventListener("DOMContentLoaded", initialize);
			} else {
				initialize();
			}
		</script>

		<%- include('common-settings') %>

		<%- include('color-overrides', { slots: ['backgroundColor', 'textColor'], defaults: require('./data/color-defaults.json')['replay-navigation'] }) %>

		<%- include('global-settings') %>

		<%- include('docs-link') %>

		<%- include('version') %>
	</body>
</html>
