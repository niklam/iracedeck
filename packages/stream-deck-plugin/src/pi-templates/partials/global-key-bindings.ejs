<!--
  Global Key Bindings Component

  Displays key binding inputs in a collapsible "Related Key Bindings" accordion.
  Key bindings are stored in global settings (shared across all action instances).
  Collapsed by default.

  Parameters:
    - keyBindings: Array with objects containing id, label, default, setting
-->
<%- include('accordion', {
  title: 'Related Key Bindings',
  open: false,
  content: keyBindings.map(function(binding) {
    return `
    <sdpi-item label="${binding.label}">
      <ird-key-binding setting="${binding.setting}" default="${binding.default}" global></ird-key-binding>
    </sdpi-item>`;
  }).join('')
}) %>
