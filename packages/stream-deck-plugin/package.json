{
  "name": "@iracedeck/stream-deck-plugin",
  "version": "1.0.0",
  "description": "Stream Deck plugin for iRacing - displays telemetry and controls pit service",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "rollup -c && npm run postbuild",
    "postbuild": "cd com.iracedeck.sd.sdPlugin/bin && npm install",
    "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.iracedeck.sd\"",
    "clean": "rimraf com.iracedeck.sd.sdPlugin/bin/plugin.js com.iracedeck.sd.sdPlugin/bin/plugin.js.map"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.0",
    "@iracedeck/iracing-sdk": "workspace:*",
    "@iracedeck/stream-deck-shared": "workspace:*",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@elgato/cli": "^1.6.0",
    "@elgato/utils": "^0.4.1",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.2.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@types/node": "~24.0.0",
    "rimraf": "^5.0.0",
    "rollup": "^4.0.2",
    "tslib": "^2.6.2",
    "typescript": "^5.2.2"
  },
  "os": [
    "win32"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT"
}
