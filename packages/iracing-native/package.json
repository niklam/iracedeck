{
  "name": "@iracedeck/iracing-native",
  "version": "0.12.0",
  "description": "Native Node.js addon for iRacing SDK - Win32 memory-mapped file and window messaging",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "install": "echo Run build manually in iracing-native to avoid extra builds",
    "build": "node scripts/build.mjs",
    "clean": "node scripts/clean.mjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist",
    "build/Release/*.node",
    "src/*.cc"
  ],
  "dependencies": {
    "node-addon-api": "8.6.0"
  },
  "devDependencies": {
    "@types/node": "25.3.5",
    "node-gyp": "12.2.0",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "iracing",
    "native",
    "node-addon",
    "win32",
    "memory-mapped-file"
  ],
  "license": "MIT"
}
