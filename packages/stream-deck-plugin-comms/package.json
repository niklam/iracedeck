{
  "name": "@iracedeck/stream-deck-plugin-comms",
  "version": "1.0.0",
  "description": "Stream Deck plugin for iRacing - Communication related functionality",
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "rollup -c && npm run postbuild",
    "postbuild": "cd com.iracedeck.sd.comms.sdPlugin/bin && npm install",
    "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.iracedeck.sd.comms\"",
    "clean": "rimraf com.iracedeck.sd.comms.sdPlugin/bin/plugin.js com.iracedeck.sd.comms.sdPlugin/bin/plugin.js.map",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@elgato/streamdeck": "^2.0.1",
    "@iracedeck/iracing-sdk": "workspace:*",
    "@iracedeck/stream-deck-shared": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@elgato/cli": "^1.7.1",
    "@elgato/utils": "^0.4.1",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^15.3.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "~24.0.15",
    "rimraf": "^5.0.10",
    "rollup": "^4.59.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "MIT"
}
