{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "customConditions": [
      "node"
    ],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "noImplicitOverride": true,
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "src/**/*.ts",
    "icons/**/*.svg"
  ],
  "exclude": [
    "node_modules"
  ]
}
