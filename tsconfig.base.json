{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "customConditions": [
      "node"
    ],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "noImplicitOverride": true,
    "declaration": true,
    "declarationMap": true
  },
  "exclude": [
    "node_modules",
    "**/node_modules",
    "**/dist",
    ".turbo"
  ]
}
