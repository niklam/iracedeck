{
  "name": "iracedeck",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm run stop:stream-deck-app && turbo run build && pnpm run start:stream-deck-app",
    "install:stream-deck": "pnpm --filter \"@iracedeck/iracing-sdk\" --filter \"@iracedeck/stream-deck-*\" install",
    "build:stream-deck": "pnpm install:stream-deck && pnpm --filter \"@iracedeck/iracing-sdk\" --filter \"@iracedeck/stream-deck-*\" build",
    "dev": "turbo run dev",
    "clean": "turbo run clean",
    "lint": "eslint packages/*/src/**",
    "lint:fix": "eslint --fix packages/*/src/**",
    "format": "prettier --check \"**/*.ts\" \"**/*.json\"",
    "format:fix": "prettier --write \"**/*.ts\" \"**/*.json\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "precommit": "pnpm lint:fix && pnpm format:fix && pnpm install && pnpm clean && pnpm build",
    "start:stream-deck-app": "start /B \"\" \"C:\\Program Files\\Elgato\\StreamDeck\\StreamDeck.exe",
    "stop:stream-deck-app": "taskkill /IM StreamDeck.exe /F || exit 0",
    "watch:stream-deck": "pnpm --filter \"@iracedeck/stream-deck-*\" run watch"
  },
  "devDependencies": {
    "@elgato/eslint-config": "^0.3.1",
    "@elgato/prettier-config": "^0.3.3",
    "@eslint/js": "^9.39.2",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@tsconfig/node20": "^20.1.2",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.0.0",
    "prettier": "^3.7.4",
    "turbo": "^2.0.0",
    "typescript": "^5.2.2",
    "vitest": "^4.0.16"
  }
}
